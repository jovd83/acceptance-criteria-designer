{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Acceptance Criteria Contract - Gherkin",
  "description": "Schema for Gherkin-style acceptance criteria contracts generated by acceptance-criteria-designer.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "format",
    "source_summary",
    "assumptions",
    "out_of_scope",
    "coverage_assessment",
    "acceptance_criteria"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0.0"
    },
    "format": {
      "type": "string",
      "const": "gherkin"
    },
    "source_summary": {
      "type": "string",
      "minLength": 1
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "coverage_assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "score",
        "covered_behaviors",
        "gaps"
      ],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "covered_behaviors": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "given",
          "when",
          "then"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^AC-GHK-[0-9]{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "given": {
            "type": "string",
            "minLength": 1
          },
          "when": {
            "type": "string",
            "minLength": 1
          },
          "then": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
